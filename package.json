{
  "name": "mailtalker",
  "version": "1.0.0",
  "description": "MailTalker - End-to-End Encrypted Stealth Chat",
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"webpack serve --mode development\" \"electron .\"",
    "build": "webpack --mode production",
    "test": "jest",
    "pack": "npx electron-builder --dir",
    "dist": "npm run build && npx electron-builder"
  },
  "build": {
    "appId": "com.mailtalker.app",
    "productName": "MailTalker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "src/core/**/*",
      "src/db/**/*"
    ],
    "win": {
      "target": "zip"
    }
  },
  "keywords": [],
  "author": {
    "name": "User",
    "email": "user@example.com"
  },
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "imap-simple": "^5.1.0",
    "jimp": "^1.6.0",
    "lucide-react": "^0.577.0",
    "nodemailer": "^8.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@tailwindcss/postcss": "^4.2.1",
    "babel-loader": "^10.1.0",
    "concurrently": "^9.2.1",
    "css-loader": "^7.1.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^30.2.0",
    "mini-css-extract-plugin": "^2.10.0",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  }
}
